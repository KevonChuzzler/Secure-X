<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp"
    android:background="@color/white">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="My Cars"
        android:textSize="24sp"
        android:textStyle="bold"
        android:textColor="@color/primary"
        android:layout_marginBottom="16dp"/>

    <ListView
        android:id="@+id/lvCars"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:layout_marginBottom="16dp"/>
        
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Add New Car"
        android:textStyle="bold"
        android:layout_marginBottom="8dp"/>
        
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">
        <EditText android:id="@+id/etMake" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:hint="Make" android:minHeight="48dp" android:layout_marginEnd="4dp"/>
        <EditText android:id="@+id/etModel" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:hint="Model" android:minHeight="48dp" android:layout_marginEnd="4dp"/>
        <EditText android:id="@+id/etYear" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:hint="Year" android:inputType="number" android:minHeight="48dp"/>
    </LinearLayout>
    
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="8dp">
        <EditText android:id="@+id/etColor" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:hint="Color" android:minHeight="48dp" android:layout_marginEnd="4dp"/>
        <EditText android:id="@+id/etPlate" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:hint="Plate" android:minHeight="48dp" android:layout_marginEnd="4dp"/>
    </LinearLayout>

    <Spinner
        android:id="@+id/spnType"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:layout_marginBottom="8dp"
        android:entries="@array/vehicle_types"/>

    <Button
        android:id="@+id/btnAddCar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Save Car"
        android:backgroundTint="@color/accent"
        android:textColor="@color/black"/>

</LinearLayout>
