<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp"
    android:background="@color/white">

    <TextView
        android:id="@+id/tvLocationName"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Select a Parking Spot"
        android:textSize="22sp"
        android:textStyle="bold"
        android:textColor="@color/primary"
        android:layout_marginBottom="8dp"/>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="16dp">
        <View android:layout_width="20dp" android:layout_height="20dp" android:background="@color/green_free" android:layout_marginEnd="6dp"/>
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Available" android:layout_marginEnd="16dp"/>
        <View android:layout_width="20dp" android:layout_height="20dp" android:background="@color/red_taken" android:layout_marginEnd="6dp"/>
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Taken" android:layout_marginEnd="16dp"/>
        <View android:layout_width="20dp" android:layout_height="20dp" android:background="@color/primary" android:layout_marginEnd="6dp"/>
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Selected"/>
    </LinearLayout>

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="ENTRANCE"
        android:textAlignment="center"
        android:textStyle="bold"
        android:background="#EEEEEE"
        android:padding="8dp"
        android:layout_marginBottom="16dp"/>

    <GridLayout
        android:id="@+id/gridSpots"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:columnCount="5"
        android:rowCount="5"
        android:layout_gravity="center"
        android:layout_marginBottom="16dp"/>

    <TextView
        android:id="@+id/tvSelectedSpot"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="No spot selected"
        android:textSize="18sp"
        android:textAlignment="center"
        android:layout_marginBottom="16dp"
        android:textStyle="italic"/>

    <Button
        android:id="@+id/btnProceedBooking"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Proceed to Booking"
        android:backgroundTint="@color/accent"
        android:textColor="@color/black"/>

</LinearLayout>
